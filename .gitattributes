# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf

# Godot text resources
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.uid text eol=lf
*.import text eol=lf
*.cfg text eol=lf
*.godot text eol=lf
*.svg text eol=lf
*.mtl text eol=lf

# Binary assets: avoid line-based merges
*.png binary
*.glb binary
*.zip binary
*.obj binary
