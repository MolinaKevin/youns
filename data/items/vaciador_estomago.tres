[gd_resource type="Resource" script_class="ItemData" load_steps=6 format=3 uid="uid://item_vaciador"]

[ext_resource type="Script" uid="uid://utilcb2pt1mr" path="res://data/items/item_data.gd" id="1_itemdata"]
[ext_resource type="Script" path="res://data/items/item_effect_set_stat.gd" id="2_setstat"]
[ext_resource type="Script" uid="uid://cwagkiwwms41h" path="res://data/items/item_effect_status.gd" id="3_status"]
[ext_resource type="Script" path="res://data/items/item_effect_force_emotion.gd" id="4_force"]
[ext_resource type="Texture2D" path="res://assets/icons/icon_4.png" id="5_icon"]

[sub_resource type="Resource" id="Resource_hambre"]
script = ExtResource("2_setstat")
stat_key = "hambre"
value = 100.0

[sub_resource type="Resource" id="Resource_is_hungry"]
script = ExtResource("3_status")
status_key = "is_hungry"
value = true

[sub_resource type="Resource" id="Resource_emotion"]
script = ExtResource("4_force")
emotion_name = "hungry"

[resource]
script = ExtResource("1_itemdata")
id = "vaciador_estomago"
name = "Vaciador de Estómago"
description = "Deja al Youn con hambre máxima."
icon = ExtResource("5_icon")
effects = [SubResource("Resource_hambre"), SubResource("Resource_is_hungry"), SubResource("Resource_emotion")]
