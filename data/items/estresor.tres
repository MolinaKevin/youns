[gd_resource type="Resource" script_class="ItemData" load_steps=5 format=3 uid="uid://item_estresor"]

[ext_resource type="Script" uid="uid://utilcb2pt1mr" path="res://data/items/item_data.gd" id="1_itemdata"]
[ext_resource type="Script" path="res://data/items/item_effect_set_stat.gd" id="2_setstat"]
[ext_resource type="Script" path="res://data/items/item_effect_force_emotion.gd" id="3_force"]
[ext_resource type="Texture2D" path="res://assets/icons/icon_5.png" id="4_icon"]

[sub_resource type="Resource" id="Resource_estres"]
script = ExtResource("2_setstat")
stat_key = "estres"
value = 100.0

[sub_resource type="Resource" id="Resource_emotion"]
script = ExtResource("3_force")
emotion_name = "stressed"

[resource]
script = ExtResource("1_itemdata")
id = "estresor"
name = "Estresor"
description = "Lleva el estrés del Youn al máximo."
icon = ExtResource("4_icon")
effects = [SubResource("Resource_estres"), SubResource("Resource_emotion")]
